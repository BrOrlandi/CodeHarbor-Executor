{
  "name": "codeharbor-executor",
  "version": "0.2.0",
  "description": "Node.js code execution service for CodeHarbor n8n node",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon --ignore './dependencies-cache/' --ignore './executions/' --ignore './bruno-rest-client/' index.js",
    "test": "jest --config tests/jest.config.js",
    "test:unit": "jest --config tests/jest.config.js --selectProjects unit",
    "test:e2e": "jest --config tests/jest.config.js --selectProjects e2e",
    "test:coverage": "jest --config tests/jest.config.js --selectProjects unit --coverage"
  },
  "dependencies": {
    "body-parser": "^1.20.3",
    "dotenv": "^16.4.7",
    "express": "^4.21.2"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.1.9"
  },
  "packageManager": "pnpm@9.15.4+sha512.b2dc20e2fc72b3e18848459b37359a32064663e5627a51e4c74b2c29dd8e8e0491483c3abb40789cfd578bf362fb6ba8261b05f0387d76792ed6e23ea3b1b6a0"
}
